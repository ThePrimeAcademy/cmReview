{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run install:all && npm run build"
  },
  "deploy": {
    "startCommand": "npm start --prefix backend",
    "healthcheckPath": "/api/auth",
    "restartPolicyType": "ON_FAILURE"
  }
}
