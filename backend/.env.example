# Where to pull synced ClassMarker webhook results from (progressReport prod)
EXPORT_URL=https://progressreport-production.up.railway.app/api/webhooks/classmarker/export
# Must match the EXPORT_TOKEN env var set on the progressReport Railway service
EXPORT_TOKEN=changeme
PORT=4180
# Shared access password for hosted deployments. Leave unset locally to
# disable the login gate entirely.
APP_PASSWORD=
